{
  "name": "ai-job-hunter-monorepo",
  "private": true,
  "packageManager": "pnpm@10.8.1",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "docker:up": "docker compose -f infra/docker/docker-compose.yml up --build -d",
    "docker:down": "docker compose -f infra/docker/docker-compose.yml down -v",
    "ci": "pnpm lint && pnpm typecheck && pnpm build"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.6.2"
  }
}
